{
  "buildCommand": "cd ReactFrontend && npm install && npm run build",
  "outputDirectory": "ReactFrontend/dist/public",
  "framework": "vite",
  "functions": {
    "api/**": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
